{
  "$schema": "../../schemas/hooks.schema.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"^git(\\\\s|$)\"",
        "description": "Block git hook-bypass flags so pre-commit, commit-msg, and pre-push protections are not skipped.",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"^git\\\\s+push(\\\\s|$)\"",
        "description": "Warn before git push so the current diff gets reviewed before publishing changes.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/pre-bash-git-push-reminder.js';require('fs').existsSync(s)&&require(s)\""
          }
        ]
      },
      {
        "matcher": "Write",
        "description": "Warn about non-standard documentation file paths before writes.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/doc-file-warning.js';require('fs').existsSync(s)&&require(s)\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "description": "Block edits to formatter and linter config files instead of weakening validation rules.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/config-protection.js';require('fs').existsSync(s)&&require(s)\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "description": "Run lightweight quality-gate checks after edits.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/quality-gate.js';require('fs').existsSync(s)&&require(s)\"",
            "async": true,
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "description": "Auto-format JS and TS files after edits.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/post-edit-format.js';require('fs').existsSync(s)&&require(s)\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "description": "Queue a targeted TypeScript check after editing TS files.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/post-edit-typecheck.js';require('fs').existsSync(s)&&require(s)\"",
            "async": true,
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "description": "Warn when edited JS or TS files still contain console.log statements.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/post-edit-console-warn.js';require('fs').existsSync(s)&&require(s)\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "description": "Inject prior session summary as additional context for cross-session continuity.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/session-start.js';require('fs').existsSync(s)&&require(s)\"",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "description": "Persist a session summary so the next session can resume with context.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/session-stop.js';require('fs').existsSync(s)&&require(s)\"",
            "timeout": 10
          }
        ]
      },
      {
        "description": "Delete temporary async typecheck state for the current session.",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/post-edit-typecheck.js cleanup",
            "timeout": 10
          }
        ]
      },
      {
        "description": "Delete temporary safety backups for the current session.",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/safety-backup.js cleanup",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "description": "Snapshot workspace state before context window compaction.",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var s='./scripts/hooks/pre-compact.js';require('fs').existsSync(s)&&require(s)\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
