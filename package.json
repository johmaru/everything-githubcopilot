{
  "name": "everything-githubcopilot",
  "displayName": "Everything GitHub Copilot",
  "version": "2.0.0",
  "description": "GitHub Copilot customization pack for VS Code with repository instructions, file-based instructions, prompt files, custom agents, hooks, and skills",
  "keywords": [
    "github-copilot",
    "copilot",
    "copilot-first",
    "vscode",
    "vscode-chat",
    "copilot-customizations",
    "copilot-instructions",
    "copilot-prompts",
    "copilot-agents",
    "copilot-hooks",
    "copilot-skills",
    "github-copilot-chat",
    "ai",
    "custom-agents",
    "prompt-files",
    "instruction-files",
    "hooks",
    "skills",
    "tdd",
    "code-review",
    "security",
    "automation",
    "best-practices"
  ],
  "author": {
    "name": "johmaru"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johmaru/everything-githubcopilot.git"
  },
  "homepage": "https://github.com/johmaru/everything-githubcopilot#readme",
  "bugs": {
    "url": "https://github.com/johmaru/everything-githubcopilot/issues"
  },
  "files": [
    ".github/",
    ".vscode/",
    ".codex/",
    ".opencode/",
    "AGENTS.md",
    "schemas/",
    "scripts/ci/",
    "scripts/hooks/",
    "docs/"
  ],
  "scripts": {
    "postinstall": "echo '\n  Everything GitHub Copilot installed.\n  Active customizations live under .github/.\n  Validate with: npm run validate\n  Docs: README.md and docs/migration-status.md\n'",
    "lint": "eslint . && markdownlint '**/*.md' --ignore node_modules",
    "validate": "node scripts/ci/validate-github-hooks.js && node scripts/ci/validate-copilot-customizations.js && node scripts/ci/validate-no-personal-paths.js",
    "test:ci": "node tests/ci/validators.test.js",
    "test:hooks": "node tests/hooks/db.test.js",
    "test": "npm run validate && npm run test:ci && npm run test:hooks"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "ajv": "^8.18.0",
    "better-sqlite3": "^12.8.0",
    "sqlite-vec": "^0.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "c8": "^10.1.2",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "markdownlint-cli": "^0.47.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.9.2+sha512.1fc009bc09d13cfd0e19efa44cbfc2b9cf6ca61482725eb35bbc5e257e093ebf4130db6dfe15d604ff4b79efd8e1e8e99b25fa7d0a6197c9f9826358d4d65c3c"
}
