{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://everything-githubcopilot.local/schemas/hooks.schema.json",
  "type": "object",
  "required": ["hooks"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "hooks": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["hooks"],
          "properties": {
            "matcher": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "hooks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "command": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "minItems": 1
                      }
                    ]
                  },
                  "url": {
                    "type": "string"
                  },
                  "prompt": {
                    "type": "string"
                  },
                  "timeout": {
                    "type": "number"
                  },
                  "async": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "additionalProperties": true
}